@import "tailwindcss";

@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap');

@theme {
  --font-sans: 'Outfit', sans-serif;
  --color-brand-navy: #1E1B4B;
  --color-brand-purple: #4C1D95;
  --color-brand-rich-purple: #6B21A8;
  --color-brand-lavender: #E9D5FF;
  --color-brand-gold: #E2AD30;
  --color-brand-coral: #F43F5E;
}

:root {
  /* Brand Colors Fallbacks */
  --bg-color: #FFFFFF;
  --text-primary: #1E1B4B; /* Deep Navy Blue */
  --text-secondary: #4b5563; /* Soft slate/navy for reading */
  --accent-lavender: #E9D5FF; /* Muted Purple */
  --accent-lavender-light: #Faf5ff; /* Very light purple/white */
  --accent-gold: #E2AD30; /* Golden text/accents */
  --success-green: #10B981; 
  --success-green-light: #d1fae5;
  --cta-coral: #F43F5E; 
  --cta-coral-hover: #e11d48;

  /* Shadows */
  --shadow-sm: 0 4px 12px rgba(47, 29, 79, 0.05);
  --shadow-md: 0 10px 30px rgba(47, 29, 79, 0.08);
  --shadow-lg: 0 20px 40px rgba(47, 29, 79, 0.12);
  
  /* Borders */
  --border-radius-sm: 8px;
  --border-radius-md: 16px;
  --border-radius-lg: 24px;
  --border-radius-xl: 32px;

  /* Typography */
  --font-family: 'Outfit', sans-serif;
}


  /* Typography */
  --font-family: 'Outfit', sans-serif;
}

html,
body {
  padding: 0;
  margin: 0;
  font-family: var(--font-family);
  background-color: var(--bg-color);
  color: var(--text-primary);
  line-height: 1.6;
  scroll-behavior: smooth;
}

h1, h2, h3, h4, h5, h6 {
  margin: 0;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.2;
}

p {
  margin: 0 0 1rem 0;
  color: var(--text-secondary);
}

a {
  color: inherit;
  text-decoration: none;
}

* {
  box-sizing: border-box;
}

/* Base Utility Classes */
.container {
  width: 100%;
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 24px;
}

.section {
  padding: 80px 0;
}

.section-tight {
  padding: 40px 0;
}

@media (max-width: 768px) {
  .section {
    padding: 60px 0;
  }
}

/* Premium Card System */
.premium-card {
  background: var(--bg-color);
  border-radius: var(--border-radius-lg);
  box-shadow: var(--shadow-sm);
  padding: 32px;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  border: 1px solid rgba(230, 224, 248, 0.5); /* Subtle lavender border */
}

.premium-card:hover {
  transform: translateY(-5px);
  box-shadow: var(--shadow-md);
}

/* Typography styles */
.hero-headline {
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  margin-bottom: 24px;
}

.section-headline {
  font-size: clamp(2rem, 4vw, 2.75rem);
  font-weight: 600;
  text-align: center;
  margin-bottom: 48px;
}

/* Soft gradients */
.bg-gradient-lavender {
  background: linear-gradient(180deg, var(--accent-lavender-light) 0%, rgba(255,255,255,1) 100%);
}

.bg-gradient-hero {
  background: radial-gradient(circle at 50% -20%, var(--accent-lavender-light) 0%, rgba(255,255,255,0) 70%);
}

/* Button System */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16px 32px;
  border-radius: 50px;
  font-weight: 600;
  font-size: 1.1rem;
  cursor: pointer;
  transition: all 0.2s ease;
  border: none;
  gap: 8px;
}

.btn-primary {
  background-color: var(--cta-coral);
  color: white;
  box-shadow: 0 8px 20px rgba(255, 111, 97, 0.3);
}

.btn-primary:hover {
  background-color: var(--cta-coral-hover);
  transform: translateY(-2px);
  box-shadow: 0 10px 25px rgba(255, 111, 97, 0.4);
}

.btn-secondary {
  background-color: var(--accent-lavender);
  color: var(--text-primary);
}

.btn-secondary:hover {
  background-color: #d8cfee;
}

.btn-outline {
  background-color: transparent;
  color: var(--text-primary);
  border: 2px solid var(--accent-lavender);
}

.btn-outline:hover {
  border-color: var(--text-primary);
}

.btn-full {
  width: 100%;
}

/* Icons styling */
.icon-gold {
  color: var(--accent-gold);
}
.icon-lavender {
  color: var(--accent-lavender);
}
.icon-green {
  color: var(--success-green);
}

/* Mobile Sticky CTA Area */
.mobile-sticky-cta {
  display: none;
}

@media (max-width: 768px) {
  .mobile-sticky-cta {
    display: flex;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: white;
    padding: 16px 24px;
    box-shadow: 0 -4px 12px rgba(47, 29, 79, 0.08);
    z-index: 100;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
}
